  <fields><fullName>Latitude__c</fullName><label>Latitude</label><type>Number</type><precision>10</precision><scale>7</scale><required>true</required></fields>
  <fields><fullName>Longitude__c</fullName><label>Longitude</label><type>Number</type><precision>10</precision><scale>7</scale><required>true</required></fields>
  <fields><fullName>Total_Ports__c</fullName><label>Total de Portas</label><type>Number</type><precision>5</precision><scale>0</scale><required>true</required></fields>
  <fields><fullName>Available_Ports__c</fullName><label>Portas Disponíveis</label><type>Number</type><precision>5</precision><scale>0</scale><required>true</required></fields>
