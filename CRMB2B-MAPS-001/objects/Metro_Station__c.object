  <fields><fullName>Latitude__c</fullName><label>Latitude</label><type>Number</type><precision>10</precision><scale>7</scale><required>true</required></fields>
  <fields><fullName>Longitude__c</fullName><label>Longitude</label><type>Number</type><precision>10</precision><scale>7</scale><required>true</required></fields>
